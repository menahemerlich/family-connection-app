{
  "name": "family-connection",
  "version": "0.1.0",
  "main": "expo-router/entry",
  "scripts": {
    "start": "cross-env EXPO_NO_TELEMETRY=1 expo start",
    "android": "cross-env EXPO_NO_TELEMETRY=1 expo start --android",
    "ios": "cross-env EXPO_NO_TELEMETRY=1 expo start --ios",
    "web": "cross-env EXPO_NO_TELEMETRY=1 expo start --web",
    "build:web": "expo export --platform web",
    "lint": "eslint . --ext .ts,.tsx",
    "typecheck": "node ./node_modules/typescript/bin/tsc --noEmit",
    "functions:build": "cd functions && npm run build",
    "functions:deploy": "firebase deploy --only functions",
    "deploy:hosting": "firebase deploy --only hosting",
    "deploy:rules": "firebase deploy --only firestore:rules,storage:rules"
  },
  "dependencies": {
    "@expo/vector-icons": "~14.0.4",
    "@livekit/react-native": "^2.10.2",
    "@livekit/react-native-webrtc": "^144.0.0",
    "@react-native-async-storage/async-storage": "^1.23.1",
    "@sentry/react-native": "~5.24.3",
    "@tanstack/react-query": "^5.51.1",
    "expo": "~51.0.28",
    "expo-apple-authentication": "~6.4.2",
    "expo-av": "~14.0.7",
    "expo-constants": "~16.0.2",
    "expo-font": "~12.0.10",
    "expo-image": "~1.13.0",
    "expo-image-picker": "~15.1.0",
    "expo-linking": "~6.3.1",
    "expo-localization": "~15.0.3",
    "expo-location": "~17.0.1",
    "expo-notifications": "~0.28.16",
    "expo-router": "~3.5.23",
    "expo-secure-store": "~13.0.2",
    "expo-splash-screen": "~0.27.5",
    "expo-status-bar": "~1.12.1",
    "expo-updates": "~0.25.28",
    "firebase": "^10.13.0",
    "i18next": "^23.12.2",
    "livekit-client": "^2.5.0",
    "nativewind": "~4.1.23",
    "react": "18.2.0",
    "react-dom": "18.2.0",
    "react-hook-form": "^7.52.1",
    "react-i18next": "^15.0.0",
    "react-native": "0.74.5",
    "react-native-calendars": "^1.1305.0",
    "react-native-gesture-handler": "~2.16.1",
    "react-native-reanimated": "~3.10.1",
    "react-native-safe-area-context": "4.10.5",
    "react-native-screens": "3.31.1",
    "react-native-svg": "15.2.0",
    "react-native-web": "~0.19.10",
    "tailwindcss": "^3.4.4",
    "zod": "^3.23.8",
    "zustand": "^4.5.4"
  },
  "devDependencies": {
    "@babel/core": "^7.20.0",
    "@types/react": "~18.2.79",
    "cross-env": "^7.0.3",
    "eslint": "^8.57.0",
    "eslint-config-expo": "^7.1.2",
    "prettier": "^3.3.3",
    "typescript": "~5.3.3"
  },
  "overrides": {
    "expo-font": "~12.0.10"
  },
  "engines": {
    "node": ">=20.0.0"
  },
  "private": true
}
