rules_version = '2';

service cloud.firestore {
  match /databases/{database}/documents {

    function isSignedIn() {
      return request.auth != null;
    }

    function isMe(uid) {
      return isSignedIn() && request.auth.uid == uid;
    }

    function isFamilyMember(familyId) {
      return isSignedIn() && exists(/databases/$(database)/documents/families/$(familyId)/members/$(request.auth.uid));
    }

    function isFamilyOwner(familyId) {
      return isSignedIn() &&
        get(/databases/$(database)/documents/families/$(familyId)).data.ownerUid == request.auth.uid;
    }

    function isFamilyAdmin(familyId) {
      return isFamilyOwner(familyId) ||
        (isFamilyMember(familyId) &&
         get(/databases/$(database)/documents/families/$(familyId)/members/$(request.auth.uid)).data.role in ['owner', 'admin']);
    }

    // ----- USERS -----
    match /users/{uid} {
      allow read: if isSignedIn();
      allow create: if isMe(uid);
      allow update, delete: if isMe(uid);
    }

    // ----- FAMILIES -----
    match /families/{familyId} {
      allow read: if isFamilyMember(familyId);
      allow create: if isSignedIn() && request.resource.data.ownerUid == request.auth.uid;
      allow update: if isFamilyAdmin(familyId);
      allow delete: if isFamilyOwner(familyId);

      // Members
      match /members/{memberUid} {
        allow read: if isFamilyMember(familyId);
        // Self-join via Cloud Function (acceptInvite); allow self-create as fallback for owner during family creation
        allow create: if isMe(memberUid) || isFamilyAdmin(familyId);
        allow update: if isMe(memberUid) || isFamilyAdmin(familyId);
        allow delete: if isMe(memberUid) || isFamilyAdmin(familyId);
      }

      // Invites
      match /invites/{inviteId} {
        allow read: if isFamilyAdmin(familyId);
        allow create, update, delete: if isFamilyAdmin(familyId);
      }

      // Chats
      match /chats/{chatId} {
        allow read: if isFamilyMember(familyId) &&
          (resource.data.type == 'group' || request.auth.uid in resource.data.participants);
        allow create: if isFamilyMember(familyId) &&
          request.auth.uid in request.resource.data.participants;
        allow update: if isFamilyMember(familyId) &&
          (resource.data.type == 'group' || request.auth.uid in resource.data.participants);
        allow delete: if isFamilyAdmin(familyId);

        match /messages/{msgId} {
          allow read: if isFamilyMember(familyId);
          allow create: if isFamilyMember(familyId) &&
            request.resource.data.senderId == request.auth.uid;
          allow update: if isFamilyMember(familyId) &&
            (resource.data.senderId == request.auth.uid ||
             // allow only reactions/readBy field updates by other members
             request.resource.data.diff(resource.data).affectedKeys().hasOnly(['reactions', 'readBy']));
          allow delete: if isFamilyMember(familyId) &&
            (resource.data.senderId == request.auth.uid || isFamilyAdmin(familyId));
        }

        match /typing/{uid} {
          allow read: if isFamilyMember(familyId);
          allow write: if isMe(uid);
        }
      }

      // Album
      match /album/{photoId} {
        allow read: if isFamilyMember(familyId);
        allow create: if isFamilyMember(familyId) &&
          request.resource.data.uploadedBy == request.auth.uid;
        allow update: if isFamilyMember(familyId) &&
          resource.data.uploadedBy == request.auth.uid;
        allow delete: if isFamilyMember(familyId) &&
          (resource.data.uploadedBy == request.auth.uid || isFamilyAdmin(familyId));
      }

      // Events
      match /events/{eventId} {
        allow read: if isFamilyMember(familyId);
        allow create: if isFamilyMember(familyId);
        allow update, delete: if isFamilyMember(familyId) &&
          (resource.data.createdBy == request.auth.uid || isFamilyAdmin(familyId));
      }

      // Lists (shopping/todo)
      match /lists/{listId} {
        allow read: if isFamilyMember(familyId);
        allow create, update: if isFamilyMember(familyId);
        allow delete: if isFamilyMember(familyId) &&
          (resource.data.createdBy == request.auth.uid || isFamilyAdmin(familyId));
      }

      // Family Tree
      match /tree/{nodeId} {
        allow read: if isFamilyMember(familyId);
        allow write: if isFamilyAdmin(familyId);
      }

      // Calls (signaling rooms)
      match /calls/{callId} {
        allow read: if isFamilyMember(familyId);
        allow create: if isFamilyMember(familyId) &&
          request.resource.data.initiator == request.auth.uid;
        allow update, delete: if isFamilyMember(familyId);
      }

      // Locations (per-user opt-in sharing)
      match /locations/{uid} {
        allow read: if isFamilyMember(familyId);
        allow write: if isMe(uid);
      }
    }
  }
}
